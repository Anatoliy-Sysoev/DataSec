@startuml
!theme plain
left to right direction
skinparam shadowing false

title DataSec — Use Case диаграмма

actor "Аналитик" as Analyst
actor "Владелец данных" as Owner
actor "Руководитель" as Manager
actor "Специалист ИБ" as Sec
actor "Platform Engineer" as Platform
actor "SOC Analyst" as SOC

rectangle "DataSec Platform" {
  usecase "Войти через SSO" as UC1
  usecase "Запросить доступ к данным" as UC2
  usecase "Согласовать доступ" as UC3
  usecase "Выдать членство в LDAP-группе" as UC4
  usecase "Выполнить SQL-запрос в Trino" as UC5
  usecase "Проверить политику Ranger" as UC6
  usecase "Замаскировать чувствительные колонки" as UC7
  usecase "Применить row-level filter" as UC8
  usecase "Собрать audit event" as UC9
  usecase "Расследовать подозрительный доступ" as UC10
  usecase "Сверить фактический и согласованный доступ" as UC11
  usecase "Эксплуатировать Trino/Ranger stack" as UC12
}

Analyst --> UC1
Analyst --> UC2
Analyst --> UC5
Manager --> UC3
Owner --> UC3
Sec --> UC3
UC2 --> UC3
UC3 --> UC4
UC5 --> UC6
UC6 --> UC7
UC6 --> UC8
UC6 --> UC9
SOC --> UC10
Sec --> UC11
Platform --> UC12

@enduml
