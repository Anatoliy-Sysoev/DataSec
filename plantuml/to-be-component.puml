@startuml
!theme plain
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultTextAlignment center

title TO BE — референсная DataSec-архитектура

actor "Пользователь" as User
actor "Руководитель" as Manager
actor "Владелец данных" as DataOwner
actor "ИБ / DataSec" as Sec
actor "SOC" as SOC

package "Жизненный цикл идентичности" {
  component "HR / источник сотрудников" as HR
  component "IDM\nworkflow доступа" as IDM
}

package "Корпоративная идентичность" {
  component "Keycloak\nSSO / OIDC" as KC
  database "LDAP / FreeIPA / AD\nгруппы доступа к данным" as LDAP
}

package "Платформа доступа к данным" {
  component "Trino Coordinator\nOIDC + Ranger AC" as Trino
  component "Trino Workers" as Workers
  component "Apache Ranger Admin HA" as Ranger
  component "Ranger UserSync\nодин активный экземпляр" as UserSync
  database "Ranger DB\nPostgreSQL" as RangerDB
  component "Ranger Trino Plugin\npolicy cache + audit" as Plugin
  database "Источники данных" as DS
}

package "Аудит и мониторинг" {
  database "Audit Backend\nOpenSearch / ES / Solr" as Audit
  component "Log Shipper\nVector / Fluent Bit / Logstash" as Shipper
  queue "Kafka\nопционально" as Kafka
  component "SIEM" as SIEM
  component "Prometheus / Grafana" as Mon
}

package "Governance" {
  database "Реестр сервисов\nTrino/Ranger inventory" as Registry
  component "Access Reconciler\nIDM ↔ LDAP ↔ Ranger" as Reconciler
}

HR --> IDM : прием / перевод / увольнение
User --> IDM : запрос доступа к данным
IDM --> Manager : согласование руководителем
IDM --> DataOwner : согласование владельцем данных
IDM --> Sec : согласование ИБ для чувствительных данных
IDM --> LDAP : управление членством в группах
IDM --> KC : управление доступом к приложению, если требуется

User --> KC : SSO-аутентификация
KC --> Trino : OIDC token
LDAP --> UserSync : users / groups
UserSync --> Ranger : синхронизация субъектов
Ranger --> RangerDB : политики / сервисы

Trino --> Plugin : проверка авторизации
Plugin --> Ranger : обновление политик
Trino --> Workers : distributed execution
Trino --> DS : запрос, если авторизован

Plugin --> Audit : access audit events
Audit --> Shipper
Shipper --> Kafka
Kafka --> SIEM
Shipper --> SIEM
SOC --> SIEM : расследования / detections

Ranger --> Mon : метрики
Trino --> Mon : метрики
UserSync --> Mon : статус sync
Audit --> Mon : ingestion lag

Registry <-- Ranger : service metadata
Registry <-- Trino : cluster/catalog metadata
Reconciler --> IDM : ожидаемые доступы
Reconciler --> LDAP : фактические группы
Reconciler --> Ranger : фактические политики через API
Reconciler --> Sec : отчет о расхождениях

@enduml
