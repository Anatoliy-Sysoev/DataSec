@startuml
!theme plain
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultTextAlignment center

title AS IS — разрозненное управление доступом к данным

actor "Пользователь" as User
actor "Согласующий" as Approver
actor "LDAP-инженер" as LdapAdmin
actor "ИБ / DataSec" as Sec

package "Заявки" {
  component "Service Desk" as SD
}

package "Identity" {
  component "Keycloak\nSSO" as KC
  database "OpenLDAP / InfraLDAP\nгруппы доступа" as LDAP
  component "IDM\nне полностью интегрирован" as IDM
}

package "Контур доступа к данным" {
  component "Trino" as Trino
  component "Apache Ranger Admin" as Ranger
  component "Ranger UserSync" as UserSync
  component "Ranger Trino Plugin" as Plugin
  database "Источники данных" as DS
}

package "Аудит" {
  database "Audit store\nSolr / ES / OpenSearch" as Audit
  component "SIEM\nопционально / частично" as SIEM
}

User --> SD : запрос доступа
SD --> Approver : маршрут согласования
Approver --> SD : согласовано
SD --> LdapAdmin : ручное исполнение
LdapAdmin --> LDAP : добавить пользователя в группу

User --> KC : SSO-вход
KC --> Trino : OIDC token / session

LDAP --> UserSync : users / groups sync
UserSync --> Ranger : импорт субъектов

Trino --> Plugin : проверка авторизации
Plugin --> Ranger : политики
Trino --> DS : запрос, если доступ разрешен
Plugin --> Audit : allow / deny audit
Audit --> SIEM : частичная выгрузка

Sec ..> Ranger : ручная проверка
Sec ..> Audit : ручной / частичный аудит

note right of LDAP
Членство в группах исполняется вручную.
Отзыв доступа зависит от ручного процесса.
end note

@enduml
